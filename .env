# ─────────────────────────────────────────────────────────────
# MIMIR Portfolio Template configuration
# Copy this file to `.env` and edit your values.
# ─────────────────────────────────────────────────────────────

# Base path for GitHub Pages. "/" for a user site (iRuperth.github.io),
# or "/repo-name/" for a project site.
VITE_BASE_PATH=/

# ── Identity ─────────────────────────────────────────────────
VITE_OWNER_NAME=Roberto Molero
VITE_OWNER_TITLE=Full Stack · IA Developer
VITE_OWNER_AVATAR=/avatar.jpeg
VITE_OWNER_BIO_EN=I'm a self taught software developer. I've been programming and tinkering with things since I was young, learning mostly on my own and building projects just to see how far I could take them. What I really love is building things that solve a real problem and make it better. I'm drawn to the cool, interesting projects, the kind that end up in the hands of a lot of people. And if there's AI involved, even better. I like owning a feature end to end and seeing the whole thing come together. More than anything, I enjoy learning and sharing what I learn. Helping others, working as a team and talking things through is where I feel most at home. I'm someone who connects easily with people, and I think the best products come out of people actually understanding each other. I've always been focused on building things with real, far reaching impact, and on growing every day. I'm always open to collaborating on interesting projects and to hearing about any opportunities that come up. If that sounds good to you, don't hesitate to reach out.
VITE_OWNER_BIO_ES=Soy desarrollador de software autodidacta. Llevo programando y trasteando con cosas desde joven, aprendiendo en gran parte por mi cuenta y montando proyectos solo por ver hasta dónde podía llevarlos. Lo que de verdad me gusta es construir cosas que resuelvan un problema real y lo hagan mejor. Me atraen los proyectos chulos e interesantes, esos que acaban en manos de mucha gente. Y si hay IA de por medio, mejor todavía. Disfruto llevando una funcionalidad de principio a fin y viendo cómo todo encaja. Más que nada, lo que me mueve es aprender y compartir lo que aprendo. Ayudar a los demás, trabajar en equipo y hablar las cosas es donde me siento más cómodo. Soy de los que hablan y conectan fácil con la gente, y creo que los mejores productos salen cuando las personas se entienden de verdad. Siempre he estado centrado en construir cosas con impacto real, de esas que pueden llegar lejos, y en crecer cada día. Siempre estoy abierto a colaborar en proyectos interesantes y a escuchar las ofertas que puedan surgir. Si te suena bien, no dudes en contactarme.

# ── Language ─────────────────────────────────────────────────
VITE_DEFAULT_LANGUAGE=en

# ── Theme & effects ──────────────────────────────────────────
VITE_ANIMATIONS=true
VITE_DEFAULT_THEME=dark

# ── Palette: light mode ─────────────────────────────────────
VITE_LIGHT_BG=#ffffff
VITE_LIGHT_BG_SOFT=#f5f5f7
VITE_LIGHT_SURFACE=#c8c8d0
VITE_LIGHT_ACCENT=#7c3aed
VITE_LIGHT_ACCENT_2=#a855f7
VITE_LIGHT_TEXT=#1a1a1a
VITE_LIGHT_TEXT_SOFT=#52525b

# ── Palette: dark mode ──────────────────────────────────────
VITE_DARK_BG=#0d1117
VITE_DARK_BG_SOFT=#161b22
VITE_DARK_SURFACE=#21262d
VITE_DARK_ACCENT=#a855f7
VITE_DARK_ACCENT_2=#c084fc
VITE_DARK_TEXT=#f0f6fc
VITE_DARK_TEXT_SOFT=#8b949e

# ── Palette: colorblind mode (Okabe-Ito safe colors) ────────
VITE_CB_ACCENT=#0072B2
VITE_CB_ACCENT_2=#E69F00

# ── Socials (leave empty to hide; populated entries appear in the
#    Contact dropdown). Email/phone get the right scheme automatically.
VITE_SOCIAL_GITHUB=https://github.com/iRuperth
VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/in/ruperthlosada/
VITE_SOCIAL_EMAIL=devrup404@gmail.com
VITE_SOCIAL_PHONE=
VITE_SOCIAL_X=
VITE_SOCIAL_INSTAGRAM=

# ── Music (optional) ─────────────────────────────────────────
VITE_MUSIC_ENABLED=true
VITE_MUSIC_FILE=/audio/ellinia.mp3
VITE_MUSIC_VOLUME=0.1

# ── Footer tagline (optional, free text shown in the footer) ─
VITE_FOOTER_TAGLINE=

# ── Dev tools (hidden by default) ────────────────────────────
# Floating liquid-glass tuner panel (bottom-right). Useful while
# designing; leave false in production.
VITE_DEV_GLASS_TUNER=false

# ── Background (neural canvas) ───────────────────────────────
# Number of neurons rendered in the animated background.
# Higher = denser web, more CPU. 0 disables them.
VITE_BACKGROUND_NEURONS=130

# ── Guestbook (Supabase) ─────────────────────────────────────
# Enable only after creating the table/view and pasting your project
# URL + anon key below. SQL to run: supabase/schema.sql
VITE_GUESTBOOK_ENABLED=true
VITE_SUPABASE_URL=https://rntgwmgpkhmmlnzmzcsn.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_l1hrt-P7kgzHIY1bai56bQ_64WSQTV6
# Table the form writes to and public view it reads from.
VITE_GUESTBOOK_TABLE=guestbook
VITE_GUESTBOOK_PUBLIC_VIEW=guestbook_public
# Field length caps (must match the SQL CHECK constraints).
VITE_GUESTBOOK_EMAIL_MAX=254
VITE_GUESTBOOK_NAME_MAX=80
VITE_GUESTBOOK_ROLE_MAX=80
VITE_GUESTBOOK_COMMENT_MAX=500
# Max number of notes displayed in the public list.
VITE_GUESTBOOK_LIST_LIMIT=50
