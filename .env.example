# ─────────────────────────────────────────────────────────────
# MIMIR Portfolio Template configuration
# Copy this file to `.env` and edit your values.
# ─────────────────────────────────────────────────────────────

# Base path for GitHub Pages (must match repo name, e.g. /mimir/)
VITE_BASE_PATH=/mimir/

# ── Identity ─────────────────────────────────────────────────
VITE_OWNER_NAME=Your Name
VITE_OWNER_TITLE=Full-Stack Developer
VITE_OWNER_AVATAR=
VITE_OWNER_BIO_EN=Short bio in English. Describe what you do and what you love building.
VITE_OWNER_BIO_ES=Bio corta en español. Describe lo que haces y lo que te apasiona construir.

# ── Language ─────────────────────────────────────────────────
VITE_DEFAULT_LANGUAGE=en

# ── Theme & effects ──────────────────────────────────────────
VITE_ANIMATIONS=true
VITE_DEFAULT_THEME=dark

# ── Palette: light mode ─────────────────────────────────────
VITE_LIGHT_BG=#ffffff
VITE_LIGHT_BG_SOFT=#f5f5f7
VITE_LIGHT_SURFACE=#c8c8d0
VITE_LIGHT_ACCENT=#7c3aed
VITE_LIGHT_ACCENT_2=#a855f7
VITE_LIGHT_TEXT=#1a1a1a
VITE_LIGHT_TEXT_SOFT=#52525b

# ── Palette: dark mode ──────────────────────────────────────
VITE_DARK_BG=#0d1117
VITE_DARK_BG_SOFT=#161b22
VITE_DARK_SURFACE=#21262d
VITE_DARK_ACCENT=#a855f7
VITE_DARK_ACCENT_2=#c084fc
VITE_DARK_TEXT=#f0f6fc
VITE_DARK_TEXT_SOFT=#8b949e

# ── Palette: colorblind mode (Okabe-Ito safe colors) ────────
VITE_CB_ACCENT=#0072B2
VITE_CB_ACCENT_2=#E69F00

# ── Socials (leave empty to hide) ────────────────────────────
VITE_SOCIAL_GITHUB=https://github.com/yourname
VITE_SOCIAL_LINKEDIN=https://linkedin.com/in/yourname
VITE_SOCIAL_EMAIL=you@example.com
VITE_SOCIAL_X=
VITE_SOCIAL_INSTAGRAM=

# ── Music (optional) ─────────────────────────────────────────
VITE_MUSIC_ENABLED=true
VITE_MUSIC_FILE=/audio/track.mp3
VITE_MUSIC_VOLUME=0.3

# ── Footer tagline (free text; leave empty to use the
#    translated default from i18n: "GOD FIRST" / "DIOS PRIMERO") ─
VITE_FOOTER_TAGLINE=

# ── Dev tools (hidden by default) ────────────────────────────
# Floating liquid-glass tuner panel (bottom-right). Useful while
# designing; leave false in production.
VITE_DEV_GLASS_TUNER=false

# ── Background (neural canvas) ───────────────────────────────
# Number of neurons rendered in the animated background.
# Higher = denser web, more CPU. 0 disables them.
VITE_BACKGROUND_NEURONS=130

# ── Guestbook (Supabase) ─────────────────────────────────────
# Enable only after creating the table/view in Supabase (run
# supabase/schema.sql) and pasting your project URL + anon key below.
VITE_GUESTBOOK_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GUESTBOOK_TABLE=guestbook
VITE_GUESTBOOK_PUBLIC_VIEW=guestbook_public
VITE_GUESTBOOK_EMAIL_MAX=254
VITE_GUESTBOOK_NAME_MAX=80
VITE_GUESTBOOK_ROLE_MAX=80
VITE_GUESTBOOK_COMMENT_MAX=500
VITE_GUESTBOOK_LIST_LIMIT=50
